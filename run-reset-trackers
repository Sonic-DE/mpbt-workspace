    sonic-screenies
    sonic-screenlocker
    sonic-silver
    sonic-silver-gtk
    sonic-ssh-password-prompt
    sonic-system-monitor-library
    sonic-system-info
    sonic-system-log
    sonic-system-monitor
    sonic-system-stats
    sonic-terminal
    sonic-terminal-tools
    sonic-thunderbolt
    sonic-vault
    sonic-welcome-center
    sonic-win
    sonic-workspace
    sonic-workspace-addons
    sonic-workspace-wallpapers
    sonic-write-daemon
    xdg-desktop-portal-sonicde
    silver-sddm
    silver-theme
"

for i in $REPOS ; do
    dir="_WORK_/sources/sonicde/$i"
    [ -d "$dir/.git" ] || continue
    cd "$dir" || continue

    tracker=$(git config autopick.tracker || true)
    master=$(git config autopick.master || true)
    upstream=$(git config autopick.upstream || true)

    [ "$tracker" ] || { echo "[$i] no autopick.tracker, skipping"; cd - >/dev/null; continue; }
    [ "$master" ] || { echo "[$i] no autopick.master, skipping"; cd - >/dev/null; continue; }
    [ "$upstream" ] || { echo "[$i] no autopick.upstream, skipping"; cd - >/dev/null; continue; }

    tracker_remote=$(echo "$tracker" | cut -d/ -f1)
    tracker_branch=$(echo "$tracker" | cut -d/ -f2-)

    git fetch --quiet --prune origin 2>/dev/null || true
    upstream_remote=$(echo "$upstream" | cut -d/ -f1)
    git fetch --quiet --prune "$upstream_remote" 2>/dev/null || { echo "[$i] failed to fetch $upstream_remote, skipping"; cd - >/dev/null; continue; }

    master_sha=$(git rev-parse "$master" 2>/dev/null) || { echo "[$i] cant resolve master, skipping"; cd - >/dev/null; continue; }
    upstream_sha=$(git rev-parse "$upstream" 2>/dev/null) || { echo "[$i] cant resolve upstream, skipping"; cd - >/dev/null; continue; }
    tracker_sha=$(git rev-parse "$tracker" 2>/dev/null) || tracker_sha=""

    matched_upstream=$(git log --cherry-mark --right-only \
        --format='%m %H' "$master_sha"..."$upstream_sha" 2>/dev/null \
        | awk '$1 == "=" { print $2; exit }')

    # --right-only omits commits already reachable from both tips. If there is
    # no patch-equivalent commit in the symmetric difference, the merge-base is
    # the last upstream commit shared literally by both histories.
    if [ -z "$matched_upstream" ]; then
        matched_upstream=$(git merge-base "$master_sha" "$upstream_sha" 2>/dev/null)
    fi

    [ "$matched_upstream" ] || { echo "[$i] histories have no shared commit, skipping"; cd - >/dev/null; continue; }

    if [ "$tracker_sha" = "$matched_upstream" ]; then
        echo "[$i] tracker already at last commit shared by both histories, skipping"
        cd - >/dev/null
        continue
    fi

    echo "[$i] setting tracker to $matched_upstream (last commit shared by both histories)"
    git push -q "$tracker_remote" "+${matched_upstream}:refs/heads/${tracker_branch}" || echo "[$i] failed to push tracker"

    cd - >/dev/null
done

echo ""
echo "Done."
