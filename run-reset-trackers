#!/bin/bash

# Set the autopick tracker to the last upstream commit patch-equivalent to a
# commit in our master. Gaps and downstream-only commits are intentional.

REPOS="
    sonic-accounts-integration
    sonic-activities
    sonic-activities-stats
    sonic-activity-manager-daemon
    sonic-audio-applet-pulse
